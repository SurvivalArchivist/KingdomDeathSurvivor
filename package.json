{
  "name": "kingdom-death-survivors",
  "version": "1.1.1",
  "description": "",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "verify": "bash scripts/verify.sh",
    "preflight": "bash scripts/preflight.sh",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac dmg zip",
    "package:win": "electron-builder --win nsis portable",
    "package:dir": "electron-builder --dir",
    "build:mac:local": "bash scripts/build-macos-local.sh",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node --test test/compile.test.js",
    "test:integration": "node --test test/dataService.test.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.kdm.survivors",
    "productName": "KDM Survivors Console",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "ui/**/*",
      "package.json",
      "!dist/**/*",
      "!release/**/*",
      "!docs/**/*",
      "!test/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "markdown-it": "^14.1.1"
  }
}
